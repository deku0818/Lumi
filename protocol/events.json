{
  "$comment": "Lumi 前端(desktop / 未来 TS TUI) 与后端的 WebSocket 协议契约。语言中立的单一事实来源：TS 端 import 本文件 derive 静态类型，Python 后端用契约测试(tests/server/test_protocol_contract.py)锁住一致性。payload 字段中 '?' 后缀表示可选。新增/改名事件或方法时，只改这里，两端的类型与测试随之收敛。",
  "version": 1,
  "events": {
    "gateway.ready": { "payload": ["model", "workspace"], "note": "连接握手，由 ws 端点直接发出" },
    "message.start": { "payload": [] },
    "message.delta": { "payload": ["text", "usage?"] },
    "thinking.delta": { "payload": ["text", "usage?"], "note": "模型思考增量（Anthropic thinking 块 / 方言 reasoning_content）" },
    "message.complete": { "payload": ["usage?"] },
    "tool.generating": { "payload": [], "note": "模型正在生成工具调用参数" },
    "tool.start": { "payload": ["name", "args", "tool_call_id", "run_id?"] },
    "tool.complete": { "payload": ["name", "output", "tool_call_id", "is_error?"], "note": "is_error=true 表示工具以异常收尾" },
    "clarify.request": { "payload": ["questions"], "note": "ask 工具，需 resume" },
    "approval.request": {
      "payload": ["tool_calls", "decisions?", "options?", "warnings?", "boundary_violations?"],
      "note": "工具审批，需 resume"
    },
    "plan.request": { "payload": ["plan_file_path", "plan_content?"], "note": "退出 plan mode 确认，需 resume" },
    "turn.complete": { "payload": ["usage?"] },
    "error": { "payload": ["message"] },
    "cron.result": {
      "payload": ["job_id", "job_name", "status", "output", "started_at", "duration_ms"],
      "note": "定时任务完成一次执行，由 DesktopDelivery 直接广播（不经 EventKind）"
    },
    "cron.running": { "payload": ["names"], "note": "当前正在执行的任务名列表，开始/结束时推送" }
  },
  "events_note": "任意事件 payload 都可能附带 parent_run_id（非空时表示属于某个子代理）",
  "methods": {
    "send_message": { "params": ["content", "tool_mode?", "execution_mode?"], "streaming": true },
    "resume": { "params": ["value"], "streaming": true },
    "stop": { "params": [], "result": ["stopped"], "note": "中止当前流式轮，取消后补发 turn.complete" },
    "list_commands": { "params": [], "result": ["commands"] },
    "run_command": { "params": ["name", "extra_text?", "tool_mode?"], "streaming": true },
    "list_providers": { "params": [], "result": ["profiles", "active"], "note": "profile.thinking[model] = {control: none|effort|toggle, levels, effort}；control 决定渲染形态，前端零推导" },
    "test_provider": { "params": ["base_url", "api_key", "model"], "result": ["ok", "error?", "latency_ms?"] },
    "set_provider": { "params": ["provider", "model"], "result": ["active", "model"] },
    "save_provider": { "params": ["profile"], "result": ["profiles", "active"] },
    "delete_provider": { "params": ["id"], "result": ["profiles", "active"] },
    "set_effort": { "params": ["provider", "model", "level"], "result": ["effort"], "note": "按模型设置思考档位（合法值=该模型 thinking.levels），持久化、下一轮生效" },
    "set_workspace": { "params": ["path"], "result": ["workspace"], "note": "切换进程级工作目录（项目切换）：权限边界、bash 会话、会话列表过滤随之切换，已有会话不迁移" },
    "list_projects": { "params": [], "result": ["projects", "current"], "note": "手动登记的项目清单（~/.lumi/projects.json），按最近使用降序" },
    "add_project": { "params": ["path", "name?"], "result": ["projects"], "note": "name 缺省用目录末端名" },
    "remove_project": { "params": ["path"], "result": ["projects"], "note": "只删清单条目，不动磁盘" },
    "rename_project": { "params": ["path", "name"], "result": ["projects"] },
    "add_folder": { "params": ["path"], "result": ["folders"], "note": "本会话临时可访问目录（仅内存，连接断开失效）" },
    "remove_folder": { "params": ["path"], "result": ["folders"] },
    "list_sessions": { "params": ["limit?"], "result": ["sessions"] },
    "new_session": { "params": [], "result": ["thread_id"] },
    "switch_session": { "params": ["thread_id"], "result": ["thread_id"] },
    "load_history": { "params": ["thread_id"], "result": ["items"] },
    "pin_session": { "params": ["thread_id", "pinned"], "result": ["thread_id", "pinned"] },
    "rename_session": { "params": ["thread_id", "title"], "result": ["thread_id", "title"] },
    "delete_session": { "params": ["thread_id"], "result": ["thread_id"] },
    "list_cron_jobs": { "params": [], "result": ["jobs"], "note": "job 含 next_run（ISO 时间或 null）" },
    "create_cron_job": { "params": ["name", "schedule", "prompt"], "result": ["job"] },
    "update_cron_job": { "params": ["job_id", "name?", "schedule?", "prompt?"], "result": ["job"] },
    "delete_cron_job": { "params": ["job_id"], "result": ["job_id"] },
    "toggle_cron_job": { "params": ["job_id", "enabled"], "result": ["job"] },
    "run_cron_job": { "params": ["job_id"], "result": ["ok"], "note": "异步触发，结果经 cron.result 推送" },
    "list_cron_runs": { "params": ["job_id", "limit?"], "result": ["runs"], "note": "run 含 thread_id（非空时可经 switch_session 跳转该次执行的会话续聊）" }
  }
}
